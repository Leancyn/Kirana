{
  "expo": {
    "name": "Kirana",
    "slug": "kirana",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/images/brand-mark.png",
    "scheme": "kirana",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/brand-mark.png",
      "resizeMode": "contain",
      "backgroundColor": "#1F6F68"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kirana.app"
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/brand-mark.png",
        "backgroundColor": "#1F6F68"
      },
      "package": "com.kirana.app"
    },
    "web": {
      "favicon": "./assets/images/brand-mark.png"
    },
    "extra": {
      "eas": {
        "projectId": "600752c6-fd7b-49fb-8e21-ff66178bf098"
      }
    },
    "plugins": ["expo-sqlite", "expo-font", "expo-web-browser", "expo-router"],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/600752c6-fd7b-49fb-8e21-ff66178bf098"
    }
  }
}
